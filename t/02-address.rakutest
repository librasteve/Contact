subtest 'postcode+4 format' => {
    my $text = q:to/END/;
        John Doe
        145 Mulberry St
        New York
        NY 10013-5231
        Tel: 555-1234
        Email: a@b.com
        END
    my $adr = Contact::Grammar.parse($text, actions => Contact::Actions.new).made.adr;
    is $adr.street,      '145 Mulberry St', 'street';
    is $adr.locality,    'New York',        'locality';
    is $adr.region,      'NY',              'region';
    is $adr.postal-code, '10013-5231',      'postal-code+4';
}

subtest 'exception on bad input' => {
    throws-like
        { Contact::Grammar.parse("", actions => Contact::Actions.new) },
        X::Contact::CannotParse,
        'bad input throws CannotParse';
}

subtest 'po-box' => {
    my $text = q:to/END/;
        John Doe
        PO Box 999
        123 Main St.
        Springfield
        IL 62704
        Tel: 555-1234
        Email: a@b.com
        END
    my $adr = Contact::Grammar.parse($text, actions => Contact::Actions.new).made.adr;
    is $adr.po-box,      'PO Box 999',   'po-box';
    is $adr.street,      '123 Main St.', 'street';
    is $adr.locality,    'Springfield',  'locality';
    is $adr.postal-code, '62704',        'postal-code';
}

subtest 'ext-address (apt)' => {
    my $text = q:to/END/;
        John Doe
        Apt 4B
        123 Main St.
        Springfield
        IL 62704
        Tel: 555-1234
        Email: a@b.com
        END
    my $adr = Contact::Grammar.parse($text, actions => Contact::Actions.new).made.adr;
    is $adr.ext-address, 'Apt 4B',       'ext-address';
    is $adr.street,      '123 Main St.', 'street';
}


subtest 'country' => {
    my $text = q:to/END/;
        John Doe
        123 Main St.
        Springfield
        IL 62704
        United States
        Tel: 555-1234
        Email: a@b.com
        END
    my $adr = Contact::Grammar.parse($text, actions => Contact::Actions.new).made.adr;
    is $adr.street,  '123 Main St.',  'street';
    is $adr.country, 'United States', 'country';
}

done-testing;
