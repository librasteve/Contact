use v6.d;
use Test;

use Contact;

subtest 'numbered street with country' => {
    my $text = q:to/END/;
        John Doe
        123 Main St.
        Springfield
        IL 62704
        Tel: 555-1234
        Email: a@b.com
        END
    my $adr = Contact::Grammar.parse($text, actions => Contact::Actions.new).made.adr;
    is $adr.street,      '123 Main St.', 'street';
    is $adr.locality,    'Springfield',  'locality';
    is $adr.region,      'IL',           'region';
    is $adr.postal-code, '62704',        'postal-code';
}

subtest 'numbered street without country' => {
    my $text = q:to/END/;
        Jane Smith
        123 Main St.
        Springfield
        IL 62704
        Tel: 555-1234
        Email: a@b.com
        END
    my $adr = Contact::Grammar.parse($text, actions => Contact::Actions.new).made.adr;
    is $adr.street,      '123 Main St.', 'street';
    is $adr.locality,    'Springfield',  'locality';
    is $adr.region,      'IL',           'region';
    is $adr.postal-code, '62704',        'postal-code';
}

subtest 'single-line city/region/postcode' => {
